# Application
BASE_URL=https://bridge.example.com
PORT=3001
NODE_ENV=production
SESSION_SECRET=change-this-to-a-random-secret

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Set to true only when the app is served over HTTPS
COOKIE_SECURE=false

# Entra ID (Microsoft)
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-client-id
ENTRA_CLIENT_SECRET=your-client-secret
# Use /callback/entra for the step-up flow, or /callback for backward compatibility
ENTRA_REDIRECT_URI=https://bridge.example.com/callback/entra

# OpenText AAF (configured via admin UI)
# These are the credentials that AAF uses to call the bridge (bridge is OIDC provider)
AAF_CLIENT_ID=opentext-aaf
AAF_CLIENT_SECRET=change-this-secret
AAF_REDIRECT_URIS=https://aaf.example.com/callback

# OpenText AAF MFA — step-up second factor (bridge acts as OIDC client to AAF)
# Set AAF_AUTHORIZE_ENDPOINT to enable the step-up flow (Entra → AAF MFA → token)
AAF_AUTHORIZE_ENDPOINT=https://aaf.example.com/authorize
# Optional: exchange the AAF MFA code for tokens to verify MFA completion
AAF_TOKEN_ENDPOINT=https://aaf.example.com/token
AAF_USERINFO_ENDPOINT=https://aaf.example.com/userinfo
# Bridge client credentials registered with AAF's own authorization server
AAF_MFA_CLIENT_ID=bridge-client
AAF_MFA_CLIENT_SECRET=change-this-mfa-secret
